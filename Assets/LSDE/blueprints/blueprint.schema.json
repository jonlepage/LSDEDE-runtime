{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"title": "BlueprintExport",
	"description": "Root container for LSDE blueprint export data.",
	"type": "object",
	"properties": {
		"version": {
			"type": "string",
			"description": "Schema version."
		},
		"exportDate": {
			"type": "string",
			"format": "date-time",
			"description": "Export timestamp."
		},
		"projectName": {
			"type": "string",
			"description": "LSDE project name."
		},
		"primaryLanguage": {
			"type": "string",
			"description": "Primary language locale code."
		},
		"locales": {
			"type": "array",
			"items": {
				"type": "string"
			},
			"description": "Included locale codes."
		},
		"dictionaries": {
			"type": "array",
			"items": {
				"$ref": "#/definitions/Dictionary"
			},
			"description": "Dictionary groups."
		},
		"signatures": {
			"type": "array",
			"items": {
				"$ref": "#/definitions/ActionSignature"
			},
			"description": "Action signature definitions."
		},
		"scenes": {
			"type": "array",
			"items": {
				"$ref": "#/definitions/BlueprintScene"
			},
			"description": "Exported scenes."
		}
	},
	"required": [
		"version",
		"exportDate",
		"locales",
		"scenes"
	],
	"definitions": {
		"BlueprintConnection": {
			"type": "object",
			"description": "A directed connection between two blocks.",
			"properties": {
				"id": {
					"type": "string",
					"description": "Connection identifier."
				},
				"fromId": {
					"type": "string",
					"description": "UUID of the source block."
				},
				"toId": {
					"type": "string",
					"description": "UUID of the target block."
				},
				"fromPort": {
					"type": "string",
					"description": "Output port on the source block."
				},
				"toPort": {
					"type": "string",
					"description": "Input port on the target block."
				},
				"fromPortIndex": {
					"type": "number",
					"description": "Zero-based index of the output port."
				}
			},
			"required": [
				"id",
				"fromId",
				"toId",
				"fromPort",
				"toPort"
			]
		},
		"BlockProperty": {
			"type": "object",
			"description": "A key-value property attached to a block.",
			"properties": {
				"key": {
					"type": "string",
					"description": "Property name."
				},
				"value": {
					"type": "string",
					"description": "Property value (string, number, or boolean serialized)."
				}
			},
			"required": [
				"key",
				"value"
			]
		},
		"ExportCondition": {
			"type": "object",
			"description": "A condition for controlling dialogue flow.",
			"properties": {
				"uuid": {
					"type": "string",
					"description": "Condition identifier."
				},
				"key": {
					"type": "string",
					"description": "Variable or state key to evaluate."
				},
				"chain": {
					"type": "string",
					"enum": [
						"|",
						"&"
					],
					"description": "Logical chain operator."
				},
				"operator": {
					"type": "string",
					"description": "Comparison operator."
				},
				"value": {
					"type": "string",
					"description": "Expected value."
				}
			},
			"required": [
				"uuid",
				"key",
				"operator",
				"value"
			]
		},
		"ExportAction": {
			"type": "object",
			"description": "An action triggered during block execution.",
			"properties": {
				"uuid": {
					"type": "string",
					"description": "Action instance identifier."
				},
				"signatureUuid": {
					"type": "string",
					"description": "UUID of the signature definition."
				},
				"actionId": {
					"type": "string",
					"description": "Human-readable signature ID for engine mapping."
				},
				"params": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"description": "Ordered action parameters."
				}
			},
			"required": [
				"uuid",
				"signatureUuid",
				"actionId",
				"params"
			]
		},
		"ChoiceItem": {
			"type": "object",
			"description": "A player choice option within a dialogue block.",
			"properties": {
				"uuid": {
					"type": "string",
					"description": "Choice identifier."
				},
				"structureKey": {
					"type": "string",
					"description": "Localization lookup key."
				},
				"label": {
					"type": "string",
					"description": "Display label."
				},
				"dialogueText": {
					"type": "object",
					"additionalProperties": {
						"type": "string"
					},
					"description": "Localized text map."
				},
				"visibilityConditions": {
					"type": "array",
					"items": {
						"$ref": "#/definitions/ExportCondition"
					},
					"description": "Visibility conditions."
				}
			},
			"required": [
				"uuid",
				"structureKey"
			]
		},
		"NativeProperties": {
			"type": "object",
			"description": "LSDE native execution properties.",
			"properties": {
				"isAsync": {
					"type": "boolean",
					"description": "Execute asynchronously."
				},
				"delay": {
					"type": "number",
					"description": "Delay in seconds before execution."
				},
				"timeout": {
					"type": "number",
					"description": "Maximum execution time in seconds."
				},
				"debug": {
					"type": "boolean",
					"description": "Debug flag."
				},
				"portPerCharacter": {
					"type": "boolean",
					"description": "Separate output ports per character."
				},
				"skipIfMissingActor": {
					"type": "boolean",
					"description": "Skip if referenced actor is absent."
				},
				"waitForBlocks": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"description": "Block UUIDs that must be visited before this block can progress."
				},
				"waitInput": {
					"type": "boolean",
					"description": "Wait for explicit player input before proceeding."
				},
				"enableDispatcher": {
					"type": "boolean",
					"description": "Dispatcher mode: all matching conditions fire async tracks."
				}
			}
		},
		"BlockCharacter": {
			"type": "object",
			"description": "A character assigned to a dialogue block.",
			"properties": {
				"uuid": {
					"type": "string",
					"description": "UUID of the character variable in the project."
				},
				"id": {
					"type": "string",
					"description": "Short identifier (tag) from Character Configuration."
				},
				"name": {
					"type": "string",
					"description": "Character display name."
				},
				"emotion": {
					"type": "string",
					"description": "Emotion label."
				},
				"emotionIntensity": {
					"type": "number",
					"description": "Emotion intensity."
				}
			},
			"required": [
				"uuid",
				"id",
				"name"
			]
		},
		"BlockScreenshot": {
			"type": "object",
			"description": "A screenshot or image for documentation.",
			"properties": {
				"src": {
					"type": "string",
					"description": "Image source."
				},
				"note": {
					"type": "string",
					"description": "Optional caption."
				}
			},
			"required": [
				"src"
			]
		},
		"BlockMetadata": {
			"type": "object",
			"description": "Non-logic metadata for display and organization.",
			"properties": {
				"color": {
					"type": "string",
					"description": "Visual color coding (hex)."
				},
				"comments": {
					"type": "string",
					"description": "Designer notes."
				},
				"tags": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"description": "Categorization tags."
				},
				"screenShots": {
					"type": "array",
					"items": {
						"$ref": "#/definitions/BlockScreenshot"
					},
					"description": "Documentation screenshots."
				},
				"characters": {
					"type": "array",
					"items": {
						"$ref": "#/definitions/BlockCharacter"
					},
					"description": "Assigned characters."
				},
				"others": {
					"type": "object",
					"additionalProperties": true,
					"description": "Additional metadata."
				}
			}
		},
		"DialogBlock": {
			"type": "object",
			"description": "A dialogue block displaying text spoken by a character.",
			"properties": {
				"uuid": {
					"type": "string",
					"description": "Unique block identifier."
				},
				"type": {
					"type": "string",
					"enum": [
						"DIALOG"
					],
					"description": "Block type."
				},
				"properties": {
					"type": "array",
					"items": {
						"$ref": "#/definitions/BlockProperty"
					},
					"description": "Custom key-value properties."
				},
				"userProperties": {
					"type": "object",
					"additionalProperties": {
						"type": "string"
					},
					"description": "User-defined properties."
				},
				"nativeProperties": {
					"$ref": "#/definitions/NativeProperties"
				},
				"isStartBlock": {
					"type": "boolean",
					"description": "Entry point of the scene."
				},
				"label": {
					"type": "string",
					"description": "Block label."
				},
				"parentLabels": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"description": "Parent folder labels."
				},
				"metadata": {
					"$ref": "#/definitions/BlockMetadata"
				},
				"structureKey": {
					"type": "string",
					"description": "Localization lookup key."
				},
				"content": {
					"type": "string",
					"description": "Raw text content."
				},
				"dialogueText": {
					"type": "object",
					"additionalProperties": {
						"type": "string"
					},
					"description": "Localized dialogue text."
				}
			},
			"required": [
				"uuid",
				"type",
				"properties"
			]
		},
		"ChoiceBlock": {
			"type": "object",
			"description": "A choice block presenting selectable options to the player.",
			"properties": {
				"uuid": {
					"type": "string",
					"description": "Unique block identifier."
				},
				"type": {
					"type": "string",
					"enum": [
						"CHOICE"
					],
					"description": "Block type."
				},
				"properties": {
					"type": "array",
					"items": {
						"$ref": "#/definitions/BlockProperty"
					},
					"description": "Custom key-value properties."
				},
				"userProperties": {
					"type": "object",
					"additionalProperties": {
						"type": "string"
					},
					"description": "User-defined properties."
				},
				"nativeProperties": {
					"$ref": "#/definitions/NativeProperties"
				},
				"isStartBlock": {
					"type": "boolean",
					"description": "Entry point of the scene."
				},
				"label": {
					"type": "string",
					"description": "Block label."
				},
				"parentLabels": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"description": "Parent folder labels."
				},
				"metadata": {
					"$ref": "#/definitions/BlockMetadata"
				},
				"choices": {
					"type": "array",
					"items": {
						"$ref": "#/definitions/ChoiceItem"
					},
					"description": "Player choice options."
				},
				"note": {
					"type": "string",
					"description": "Designer note."
				}
			},
			"required": [
				"uuid",
				"type",
				"properties"
			]
		},
		"ConditionBlock": {
			"type": "object",
			"description": "A condition block that evaluates logic to branch the dialogue flow.",
			"properties": {
				"uuid": {
					"type": "string",
					"description": "Unique block identifier."
				},
				"type": {
					"type": "string",
					"enum": [
						"CONDITION"
					],
					"description": "Block type."
				},
				"properties": {
					"type": "array",
					"items": {
						"$ref": "#/definitions/BlockProperty"
					},
					"description": "Custom key-value properties."
				},
				"userProperties": {
					"type": "object",
					"additionalProperties": {
						"type": "string"
					},
					"description": "User-defined properties."
				},
				"nativeProperties": {
					"$ref": "#/definitions/NativeProperties"
				},
				"isStartBlock": {
					"type": "boolean",
					"description": "Entry point of the scene."
				},
				"label": {
					"type": "string",
					"description": "Block label."
				},
				"parentLabels": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"description": "Parent folder labels."
				},
				"metadata": {
					"$ref": "#/definitions/BlockMetadata"
				},
				"conditions": {
					"type": "array",
					"items": {
						"type": "array",
						"items": {
							"$ref": "#/definitions/ExportCondition"
						}
					},
					"description": "Condition groups (2D array). Each group is a case evaluated in order."
				},
				"note": {
					"type": "string",
					"description": "Designer note."
				}
			},
			"required": [
				"uuid",
				"type",
				"properties"
			]
		},
		"ActionBlock": {
			"type": "object",
			"description": "An action block that triggers game state changes or events.",
			"properties": {
				"uuid": {
					"type": "string",
					"description": "Unique block identifier."
				},
				"type": {
					"type": "string",
					"enum": [
						"ACTION"
					],
					"description": "Block type."
				},
				"properties": {
					"type": "array",
					"items": {
						"$ref": "#/definitions/BlockProperty"
					},
					"description": "Custom key-value properties."
				},
				"userProperties": {
					"type": "object",
					"additionalProperties": {
						"type": "string"
					},
					"description": "User-defined properties."
				},
				"nativeProperties": {
					"$ref": "#/definitions/NativeProperties"
				},
				"isStartBlock": {
					"type": "boolean",
					"description": "Entry point of the scene."
				},
				"label": {
					"type": "string",
					"description": "Block label."
				},
				"parentLabels": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"description": "Parent folder labels."
				},
				"metadata": {
					"$ref": "#/definitions/BlockMetadata"
				},
				"actions": {
					"type": "array",
					"items": {
						"$ref": "#/definitions/ExportAction"
					},
					"description": "Triggered actions."
				},
				"note": {
					"type": "string",
					"description": "Designer note."
				}
			},
			"required": [
				"uuid",
				"type",
				"properties"
			]
		},
		"NoteBlock": {
			"type": "object",
			"description": "A designer note block for documentation purposes. Not executed at runtime.",
			"properties": {
				"uuid": {
					"type": "string",
					"description": "Unique block identifier."
				},
				"type": {
					"type": "string",
					"enum": [
						"NOTE"
					],
					"description": "Block type."
				},
				"properties": {
					"type": "array",
					"items": {
						"$ref": "#/definitions/BlockProperty"
					},
					"description": "Custom key-value properties."
				},
				"userProperties": {
					"type": "object",
					"additionalProperties": {
						"type": "string"
					},
					"description": "User-defined properties."
				},
				"nativeProperties": {
					"$ref": "#/definitions/NativeProperties"
				},
				"isStartBlock": {
					"type": "boolean",
					"description": "Entry point of the scene."
				},
				"label": {
					"type": "string",
					"description": "Block label."
				},
				"parentLabels": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"description": "Parent folder labels."
				},
				"metadata": {
					"$ref": "#/definitions/BlockMetadata"
				}
			},
			"required": [
				"uuid",
				"type",
				"properties"
			]
		},
		"BlueprintBlock": {
			"description": "A single block (node) in the dialogue blueprint. Discriminated by the \"type\" field.",
			"oneOf": [
				{
					"$ref": "#/definitions/DialogBlock"
				},
				{
					"$ref": "#/definitions/ChoiceBlock"
				},
				{
					"$ref": "#/definitions/ConditionBlock"
				},
				{
					"$ref": "#/definitions/ActionBlock"
				},
				{
					"$ref": "#/definitions/NoteBlock"
				}
			]
		},
		"BlueprintScene": {
			"type": "object",
			"description": "A scene containing dialogue blocks and connections.",
			"properties": {
				"uuid": {
					"type": "string",
					"description": "Unique scene identifier."
				},
				"label": {
					"type": "string",
					"description": "Scene name."
				},
				"note": {
					"type": "string",
					"description": "Scene-level notes."
				},
				"entryBlockId": {
					"type": "string",
					"description": "UUID of the entry block."
				},
				"date": {
					"type": "string",
					"description": "Creation or modification date."
				},
				"blocks": {
					"type": "array",
					"items": {
						"$ref": "#/definitions/BlueprintBlock"
					},
					"description": "Blocks in this scene."
				},
				"connections": {
					"type": "array",
					"items": {
						"$ref": "#/definitions/BlueprintConnection"
					},
					"description": "Connections defining dialogue flow."
				}
			},
			"required": [
				"uuid",
				"label",
				"date",
				"blocks",
				"connections"
			]
		},
		"DictionaryRow": {
			"type": "object",
			"description": "A single entry in a dictionary group.",
			"properties": {
				"key": {
					"type": "string",
					"description": "Key identifier."
				}
			},
			"required": [
				"key"
			]
		},
		"Dictionary": {
			"type": "object",
			"description": "A dictionary group for conditions and actions.",
			"properties": {
				"uuid": {
					"type": "string",
					"description": "Dictionary group identifier."
				},
				"id": {
					"type": "string",
					"description": "Group identifier."
				},
				"rows": {
					"type": "array",
					"items": {
						"$ref": "#/definitions/DictionaryRow"
					},
					"description": "Dictionary entries."
				}
			},
			"required": [
				"uuid",
				"id",
				"rows"
			]
		},
		"EnumOption": {
			"type": "object",
			"description": "An option in an enum parameter.",
			"properties": {
				"id": {
					"type": "string",
					"description": "Value identifier."
				},
				"label": {
					"type": "string",
					"description": "Display label."
				}
			},
			"required": [
				"id"
			]
		},
		"SignatureParam": {
			"type": "object",
			"description": "A parameter definition for an action signature.",
			"properties": {
				"label": {
					"type": "string",
					"description": "Parameter label."
				},
				"type": {
					"type": "string",
					"enum": [
						"boolean",
						"string",
						"number",
						"enum",
						"dictionary"
					],
					"description": "Parameter data type."
				},
				"dictionaryGroupUuid": {
					"type": "string",
					"description": "Referenced dictionary group UUID."
				},
				"enumOptions": {
					"type": "array",
					"items": {
						"$ref": "#/definitions/EnumOption"
					},
					"description": "Enum options."
				}
			},
			"required": [
				"type"
			]
		},
		"ActionSignature": {
			"type": "object",
			"description": "An action signature defining a reusable action type.",
			"properties": {
				"uuid": {
					"type": "string",
					"description": "Signature identifier."
				},
				"id": {
					"type": "string",
					"description": "Short action type identifier."
				},
				"params": {
					"type": "array",
					"items": {
						"$ref": "#/definitions/SignatureParam"
					},
					"description": "Parameter definitions."
				}
			},
			"required": [
				"uuid",
				"id",
				"params"
			]
		}
	}
}